@startuml
!theme plain
skinparam classAttributeIconSize 0
skinparam componentStyle rectangle
skinparam maxMessageSize 60
skinparam maxClassSize 60
skinparam maxwidth 50000
skinparam maxheight 50000
skinparam dpi 300
skinparam shadowing false
skinparam wrapWidth 200

package "Presentation Layer" {
    class ChartViewModel {
        + name: str
        + nodes: List<NodeViewModel>
        + links: List<LinkViewModel>
    }
    
    class NodeViewModel {
        + id: str
        + type: str
        + x: float
        + y: float
        + row: int
    }
    
    class LinkViewModel {
        + source_id: str
        + target_id: str
    }

    class ChartVisualizationObserver implements IChartObserver {
        - view: Any
        - mapper: ViewModelMapper
        - serializer: ChartDataSerializer
        - _last_view_model: Optional[ChartViewModel]
        --
        + on_stitch_count_changed(chart: ChartSection, old_count: int, new_count: int): void
        + on_node_added(chart: ChartSection, node: Node): void
        + on_link_added(chart: ChartSection, link: Link): void
        + on_row_added(chart: ChartSection, row: List[str]): void
        + on_marker_placed(chart: ChartSection, side: str, position: int): void
        + on_chart_state_changed(chart: ChartSection, event: ChartStateEvent): void
        + get_chart_view_model(chart: ChartSection): ChartViewModel
        + get_last_view_model(): Optional[ChartViewModel]
    }

    class ChartVisualizationService {
        - chart_service: ChartService
        --
        + create_visualization_observer(view: Any): ChartVisualizationObserver
        + attach_visualization_observer(chart: ChartSection, observer: Optional[ChartVisualizationObserver]): void
        + get_chart_view_model(chart: ChartSection): ChartViewModel
    }
    
    class ViewModelMapper {
        --
        + to_view_model(chart_data: ChartData): ChartViewModel
        + to_node_view_model(node: Node): NodeViewModel
        + to_link_view_model(link: Link): LinkViewModel
        + view_model_to_dict(view_model: ChartViewModel): Dict[str, Any]
    }
}

package "Domain Layer" {
    ' Interfaces
    interface IChartRepository {
        + save_chart(chart_data: ChartData): void
        + load_chart(name: str): ChartData
        + load_all_charts(): List[ChartData]
        + save_charts(charts: List[ChartData]): void
    }

    ' Services
    class ChartService {
        - chart_repository: IChartRepository
        - chart_factory: ChartSectionFactory
        - serializer: ChartDataSerializer
        - pattern_processor: PatternProcessor
        - validation_chain: ValidationHandler
        --
        + create_chart(name: str, start_side: str, sts: int, rows: int): ChartSection
        + process_pattern(chart: ChartSection, pattern: str): ExpandedPattern
        + export_chart(chart: ChartSection): ChartData
        + save_chart(chart: ChartSection): void
        + load_chart(name: str): ChartData
        + load_all_charts(): List[ChartData]
        + save_charts(charts: List[ChartSection]): void
        + join_charts(chart1: ChartSection, chart2: ChartSection): ChartSection
        + validate_chart(chart: ChartSection, request: ValidationRequest): ValidationResult
        - _create_pattern_processor(): PatternProcessor
        - _create_validation_chain(): ValidationHandler
    }
    
    class PatternProcessor {
        - pattern_parser: PatternParser
        - pattern_validator: PatternValidator
        --
        + expand_pattern(pattern: str, context: PatternContext): ExpandedPattern
        + validate_pattern(pattern: str, context: PatternContext): bool
        + process_markers(pattern: str, context: PatternContext): List[int]
        + validate_and_expand(pattern: str, context: PatternContext): ExpandedPattern
    }
    
    class ChartSectionFactory {
        --
        + create(config: ChartConfig): ChartSection
        + create_with_defaults(name: str, start_side: str, sts: int, rows: int): ChartSection
        - _create_stitch_counter(): StitchCounter
        - _create_validator(): StitchCountValidator
        - _create_validation_chain(): ValidationHandler
        - _create_row_manager(start_side: str): RowManager
        - _create_node_manager(): NodeManager
        - _create_link_manager(): LinkManager
        - _create_position_calculator(sts: int, rows: int): PositionCalculator
        - _create_marker_manager(): MarkerManager
        - _create_pattern_parser(marker_manager: MarkerManager): PatternParser
        - _create_chart_generator(position_calculator: PositionCalculator): ChartGenerator
        - _create_chart_queries(node_manager: NodeManager, row_manager: RowManager, marker_manager: MarkerManager): ChartQueries
        - _create_operation_registry(): OperationRegistry
    }
    
   class ChartSection {
      - name: str
      - start_side: str
      - observers: List[IChartObserver]
      - row_manager: RowManager
      - node_manager: NodeManager
      - link_manager: LinkManager
      - position_calculator: PositionCalculator
      - marker_manager: MarkerManager
      - pattern_parser: PatternParser
      - chart_generator: ChartGenerator
      - chart_queries: ChartQueries
      - operation_registry: OperationRegistry
      - stitch_counter: StitchCounter
      - validator: StitchCountValidator
      - validation_chain: Optional[ValidationHandler]
      --
      ' Observer management
      + attach(observer: IChartObserver): void
      + detach(observer: IChartObserver): void
      + notify_observers(event: ChartStateEvent): void
      
      ' High-level operations
      + add_row(pattern: Union[str, int], isRound: bool): ChartSection
      + add_round(pattern: Union[str, int]): ChartSection
      + cast_on_start(count: int): void
      + cast_on(count: int): ChartSection
      + place_marker(side: str, position: int): void
      + repeat_rows(patterns: List[str], count: int): void
      + repeat_rounds(patterns: List[str], count: int): void
      + join(other: ChartSection): ChartSection
      + place_on_hold(): List[Node]
      + place_on_needle(stitches_on_hold: List[Node], join_side: str): void
      
      ' Node creation
      + add_nodes(row: List[str], side: str, isRound: bool): void
      
      ' Query methods (delegate to ChartQueries)
      + get_current_row_num(): int
      + get_current_num_of_stitches(): int
      + get_stitches_on_hold(): List[Node]
      + get_row_num(side: str): int
      + get_markers(side: str): List[int]
      + find_last_stitch(): Node
      + find_first_stitch(): Node
      
      ' Properties
      + nodes: List[Node] {property}
      + links: List[Link] {property}
      + rows: List[List[str]] {property}
      
      ' Internal methods
      - _validate_and_execute_operation(operation_name: str, params: Dict, consumed: Optional[int], produced: Optional[int]): ChartSection
      - _verify_stitch_count_consistency(): void
      - _notify_stitch_count_changed(old_count: int, new_count: int): void
      - _notify_node_added(node: Optional[Node]): void
      - _notify_link_added(link: Dict): void
      - _notify_row_added(row: List[str]): void
      - _notify_marker_placed(side: str, position: int): void
   }

   class ChartQueries {
      - _node_manager: NodeManager
      - _row_manager: RowManager
      - _marker_manager: MarkerManager
      --
      + get_current_num_of_stitches(): int
      + get_current_row_num(): int
      + get_row_num(side: str): int
      + get_stitches_on_hold(): List[Node]
      + get_markers(side: str): List[int]
      + find_last_stitch(): Node
      + find_first_stitch(): Node
   }

   class ChartGenerator {
      - position_calculator: PositionCalculator
      --
      + generate_nodes(chart: ChartSection, row: List[str], context: GenerationContext): List[Node]
      + generate_links(chart: ChartSection, previous_row: List[Node], current_row: List[Node]): List[Link]
      + calculate_positions(chart: ChartSection, row: List[str], previous_stitches: List[Node]): List[float]
      + create_nodes_for_row(chart: ChartSection, row: List[str], side: str, row_num: int): void
      + add_horizontal_links(chart: ChartSection, index: int): void
   }

   class PlaceOnHoldOperation implements IChartOperation {
      --
      + execute(chart: ChartSection, params: Dict): ChartSection
      + validate(params: Dict, context: PatternContext): ValidationResult
   }

   class PlaceOnNeedleOperation implements IChartOperation {
      --
      + execute(chart: ChartSection, params: Dict): ChartSection
      + validate(params: Dict, context: PatternContext): ValidationResult
   }

   class JoinOperation implements IChartOperation {
      --
      + execute(chart: ChartSection, params: Dict): ChartSection
      + validate(params: Dict, context: PatternContext): ValidationResult
   }

   class CastOnOperation implements IChartOperation {
      --
      + execute(chart: ChartSection, params: Dict): ChartSection
      + validate(params: Dict, context: PatternContext): ValidationResult
   }

   class AddRowOperation implements IChartOperation {
      --
      + execute(chart: ChartSection, params: Dict): ChartSection
      + validate(params: Dict, context: PatternContext): ValidationResult
   }

   class CastOnAdditionalOperation implements IChartOperation {
      --
      + execute(chart: ChartSection, params: Dict): ChartSection
      + validate(params: Dict, context: PatternContext): ValidationResult
   }

    interface IMarkerProvider {
        + get_markers(side: str): List[int]
        + move_marker(side: str, position: int, shift_amount: int, num_stitches: int): void
        + remove_marker(side: str, position: int): void
    }
    
    class PatternParser {
      - CONSUME_PRODUCE: Dict[str, Tuple[int, int]]
      - marker_provider: IMarkerProvider
      --
      + expand_pattern(pattern: str, available_stitches: int, side: str): ExpandedPattern
      + split_tokens(pattern: str): List[str]
      + parse_token(token: str): Tuple[str, int]
      - _split_by_sm(pattern: str, side: str): Tuple[List[str], List[int], List[int]]
    }
    
    class RowManager {
        - rows: List[List[str]]
        - start_side: str
        - last_row_side: str
        --
        + set_last_row_side(side: str): void
        + add_row(row: List[str], isRound: bool): void
        + add_round(row: List[str]): void
        + is_wrong_side(isRound: bool): bool
        + reverse_row_if_needed(row: List[str], isRound: bool): List[str]
        + duplicate_row(index: int): List[str]
        + get_rows(): List[List[str]]
        + get_last_row_side(): str
        + get_start_side(): str
        + get_row_count(): int
        + get_row(index: int): List[str]
        + update_row(index: int, row: List[str]): void
        - _validate_row_index(index: int): void
    }
    
    class NodeManager {
        - nodes: List[Node]
        - node_counter: int
        - last_row_stitches: List[Node]
        - last_row_unconsumed_stitches: List[Node]
        - stitches_on_hold: List[Node]
        - last_row_produced: int
        --
        + create_stitch_node(stitch: str, fx: float, fy: float, row: int): Node
        + create_strand_node(row: int): Node
        + set_stitches_on_hold(): int
        + places_stitches_on_needle(stitches: List[Node]): void
        + set_last_row_unconsumed_stitches(unconsumed_stitches: List[Node]): void
        + get_stitches_on_hold(): List[Node]
        + set_last_row_produced(produced: int): void
        + get_nodes(): List[Node]
        + get_last_row_stitches(): List[Node]
        + get_last_row_unconsumed_stitches(): List[Node]
        + get_last_row_produced(): int
        + get_node_counter(): int
        + set_last_row_stitches(stitches: List[Node]): void
        + append_to_last_row_stitches(stitches: List[Node]): void
        + clear_last_row_stitches(): void
        + extend_nodes(nodes: List[Node]): void
        + increment_node_counter(amount: int): void
        + update_last_row_produced(consumed: int, produced: int): int
        + replace_nodes(nodes: List[Node]): void
    }
    
    class LinkManager {
        - links: List[Link]
        --
        + add_horizontal_link(source_id: str, target_id: str): void
        + add_vertical_link(source_id: str, target_id: str): void
        + get_links(): List[Link]
        + extend_links(links: List[Link]): void
        + replace_links(links: List[Link]): void
        + remove_invalid_links(node_ids: set): int
    }
    
    class PositionCalculator {
        - DEFAULT_SPACING: float
        - ROW_HEIGHT: float
        - BASE_Y_OFFSET: float
        --
        + set_guage(sts: int, rows: int): void
        + calculate_anchors(row: List[str], side: str, previous_stitches: List[Node], link_manager: LinkManager, node_counter: int): tuple[List[float], List[Node]]
        + centered_array(n: int, spacing: int): List[float]
        - _calculate_from_previous_row(row: List[str], side: str, previous_stitches: List[Node], link_manager: LinkManager, node_counter: int): tuple[List[float], List[Node]]
        - _add_increase_decrease_links(stitch: str, prev_i: int, current_i: int, previous_stitches: List[Node], link_manager: LinkManager, node_counter: int): void
        - _is_regular_stitch(stitch: str): bool
        - _calculate_increase_decrease_anchor(i: int, prev_i: int, previous_stitches: List[Node], side: str): float
        - _center_anchors(anchors: List[float], row: List[str]): List[float]
    }
    
    class MarkerManager implements IMarkerProvider {
        - markers_rs: List[int]
        - markers_ws: List[int]
        --
        + add_marker(side: str, position: int, num_stitches: int): void
        + get_markers(side: str): List[int]
        + move_marker(side: str, position: int, shift_amount: int, num_stitches: int): void
        + remove_marker(side: str, position: int): void
        + clear_markers(): void
        + get_markers_rs(): List[int]
        + get_markers_ws(): List[int]
        + add_marker_to_rs(position: int): void
        + add_marker_to_ws(position: int): void
    }

    abstract class ValidationHandler {
        - _next_handler: Optional[ValidationHandler]
        --
        + set_next(handler: ValidationHandler): ValidationHandler
        + handle(request: ValidationRequest): ValidationResult
        + {abstract} validate(request: ValidationRequest): ValidationResult
    }
    
    class ValidationRequest {
        + chart: ChartSection
        + pattern: Optional[str]
        + nodes: Optional[List[Node]]
        + links: Optional[List[Link]]
        + operation: Optional[str]
        + context: Optional[PatternContext]
        + consumed: Optional[int]
        + produced: Optional[int]
    }

    class StitchCountValidationHandler extends ValidationHandler {
      - validator: StitchCountValidator
      --
      + validate(request: ValidationRequest): ValidationResult
    }

   class PatternValidationHandler extends ValidationHandler {
      - validator: PatternValidator
      --
      + validate(request: ValidationRequest): ValidationResult
    }

   class OrderValidationHandler extends ValidationHandler {
      - validator: OrderValidator
      --
      + validate(request: ValidationRequest): ValidationResult
    }

    class ChartDataValidationHandler extends ValidationHandler {
        - _validator: ChartDataValidator
        --
        + validate(request: ValidationRequest): ValidationResult
    }
    
    class ValidationResult {
        + is_valid: bool
        + errors: List[str]
        + raise_if_invalid(): void
    }

    class StitchCounter {
      - current_count: int
      - history: List[StitchCountEvent]
      --
      + get_current_count(): int
      + record_operation(operation: str, consumed: int, produced: int): void
      + validate_consistency(actual_count: int): bool
      + get_history(): List[StitchCountEvent]
      + reset(count: int): void
   }

   class StitchCountValidator {
        --
        + validate_stitch_count(chart: ChartSection, consumed: int, produced: int): ValidationResult
        + validate_consistency(chart: ChartSection): ValidationResult
    }

    class PatternValidator {
        --
        + validate_pattern(pattern: str, context: PatternContext): ValidationResult
        + validate_tokens(tokens: List[str]): ValidationResult
        - _split_tokens(pattern: str): List[str]
        - _estimate_stitches(tokens: List[str], available: int): int
    }

    class OrderValidator {
        --
        + validate_order(nodes: List[Node], links: List[Link]): ValidationResult
        + validate_link_integrity(links: List[Link], nodes: List[Node]): ValidationResult
    }

    interface IChartOperation {
        + execute(chart: ChartSection, params: Dict): ChartSection
        + validate(params: Dict, context: PatternContext): ValidationResult
    }
    
    class OperationRegistry {
        - _operations: Dict[str, IChartOperation]
        --
        + register(name: str, operation: IChartOperation): void
        + get_operation(name: str): IChartOperation
        + has_operation(name: str): bool
    }

    class ValidationChainBuilder {
         - _first_handler: Optional[ValidationHandler]
         - _last_handler: Optional[ValidationHandler]
         --
         + add_stitch_count_validation(): ValidationChainBuilder
         + add_pattern_validation(): ValidationChainBuilder
         + add_order_validation(): ValidationChainBuilder
         + add_chart_data_validation(): ValidationChainBuilder
         + build(): Optional[ValidationHandler]
         - _add_handler(handler: ValidationHandler): ValidationChainBuilder
    }
}

package "Data Layer" {
    class ChartData {
        + name: str
        + nodes: List[Node]
        + links: List[Link]
    }

    class ChartDataSerializer {
        --
        + serialize(chart: ChartSection): str
        + serialize_deterministic(chart: ChartSection): str
        + serialize_deterministic_from_chart_data(chart_data: ChartData): str
        + to_chart_data(chart: ChartSection): ChartData
        + order_nodes(nodes: List[Node]): List[Node]
        + order_links(links: List[Link]): List[Link]
        - _convert_nodes(nodes: List[Node]): List[Node]
        - _convert_links(links: List[Link]): List[Link]
        - _node_to_dict(node: Node): Dict[str, Any]
        - _link_to_dict(link: Link): Dict[str, Any]
        - _convert_single_node(node_dict: Dict[str, Any]): Node
        - _convert_single_link(link_dict: Dict[str, Any]): Link
    }
    
    class Node {
        + id: str
        + type: str
        + row: int
        + fx: float
        + fy: float
    }
    
    class Link {
        + source: str
        + target: str
    }
    
    class ChartConfig {
        + name: str
        + start_side: str
        + sts: int
        + rows: int
    }

    class ChartRepository implements IChartRepository {
        - data_path: Path
        - validator: ChartDataValidator
        - serializer: ChartDataSerializer
        - view_model_mapper: ViewModelMapper
        --
        + save_chart(chart_data: ChartData): void
        + load_chart(name: str): ChartData
        + load_all_charts(): List[ChartData]
        + save_charts(charts: List[ChartData]): void
        - _dict_to_chart_data(data: dict): ChartData
    }
    
    class ChartDataValidator {
        --
        + validate_chart_data(chart_data: ChartData): ValidationResult
        + validate(chart_data: ChartData): ValidationResult
        - _validate_nodes(nodes: List[Node]): List[str]
        - _validate_links(links: List[Link], nodes: List[Node]): List[str]
    }
    
    class PatternContext {
        + available_stitches: int
        + side: str
        + markers: List[int]
        + last_row_side: str
        + is_round: bool
    }
    
    class ExpandedPattern {
        + stitches: List[str]
        + consumed: int
        + produced: int
        + markers: List[int]
    }

    interface IChartObserver {
        + on_stitch_count_changed(chart: ChartSection, old_count: int, new_count: int): void
        + on_node_added(chart: ChartSection, node: Node): void
        + on_link_added(chart: ChartSection, link: Link): void
        + on_row_added(chart: ChartSection, row: List[str]): void
        + on_marker_placed(chart: ChartSection, side: str, position: int): void
        + on_chart_state_changed(chart: ChartSection, event: ChartStateEvent): void
    }
    
    class ChartStateEvent {
        + event_type: str
        + chart: Any
        + data: Dict[str, Any]
        + timestamp: datetime
    }

    class StitchCountEvent {
        + operation: str
        + consumed: int
        + produced: int
        + old_count: int
        + new_count: int
        + timestamp: Optional[datetime]
    }

    class GenerationContext {
        + row: List[str]
        + side: str
        + row_num: int
        + previous_stitches: List[Node]
        + is_round: bool
    }
}

' ============================================
' INTERFACE IMPLEMENTATIONS
' ============================================
ChartRepository ..|> IChartRepository : implements
MarkerManager ..|> IMarkerProvider : implements
ChartVisualizationObserver ..|> IChartObserver : implements
CastOnOperation ..|> IChartOperation : implements
AddRowOperation ..|> IChartOperation : implements
CastOnAdditionalOperation ..|> IChartOperation : implements
PlaceOnHoldOperation ..|> IChartOperation : implements
PlaceOnNeedleOperation ..|> IChartOperation : implements
JoinOperation ..|> IChartOperation : implements

' ============================================
' PRESENTATION LAYER RELATIONSHIPS
' ============================================
ViewModelMapper --> ChartData : converts from
ViewModelMapper --> Node : converts from
ViewModelMapper --> Link : converts from
ChartViewModel *-- NodeViewModel : contains
ChartViewModel *-- LinkViewModel : contains
ChartVisualizationService --> ChartService : uses
ChartVisualizationObserver --> ViewModelMapper : uses
ChartVisualizationObserver --> ChartDataSerializer : uses
ChartVisualizationObserver --> ChartSection : observes

' ============================================
' DOMAIN LAYER - OBSERVER PATTERN
' ============================================
ChartSection --> IChartObserver : notifies
ChartVisualizationObserver --> ChartSection : observes
ChartVisualizationObserver ..> ChartStateEvent : uses

' ============================================
' DOMAIN LAYER - SERVICE & FACTORY
' ============================================
ChartService --> IChartRepository : uses
ChartService --> PatternProcessor : uses
ChartService --> ChartSectionFactory : uses
ChartService --> ChartDataSerializer : uses
ChartService --> ChartConfig : uses
ChartService --> ValidationHandler : uses

ChartSectionFactory --> ChartSection : creates
ChartSectionFactory --> StitchCounter : creates
ChartSectionFactory --> StitchCountValidator : creates
ChartSectionFactory --> RowManager : creates
ChartSectionFactory --> NodeManager : creates
ChartSectionFactory --> LinkManager : creates
ChartSectionFactory --> PositionCalculator : creates
ChartSectionFactory --> MarkerManager : creates
ChartSectionFactory --> PatternParser : creates
ChartSectionFactory --> ChartGenerator : creates
ChartSectionFactory --> ChartQueries : creates\n(with managers)
ChartSectionFactory --> NodeManager : provides to\nChartQueries
ChartSectionFactory --> RowManager : provides to\nChartQueries
ChartSectionFactory --> MarkerManager : provides to\nChartQueries
ChartSectionFactory --> OperationRegistry : creates
ChartSectionFactory --> ChartConfig : uses
ChartSectionFactory --> ValidationHandler : creates
ChartSectionFactory ..> IMarkerProvider : uses

' ============================================
' DOMAIN LAYER - CHART SECTION COMPOSITION
' ============================================
ChartSection *-- RowManager : composition
ChartSection *-- NodeManager : composition
ChartSection *-- LinkManager : composition
ChartSection *-- PositionCalculator : composition
ChartSection *-- MarkerManager : composition
ChartSection *-- PatternParser : composition
ChartSection *-- StitchCounter : composition
ChartSection *-- StitchCountValidator : composition
ChartSection --> ChartGenerator : uses
ChartSection --> ChartQueries : uses
ChartSection --> OperationRegistry : uses
ChartSection --> ValidationHandler : uses

' ============================================
' DOMAIN LAYER - CHART QUERIES
' ============================================
ChartQueries *-- NodeManager : composition
ChartQueries *-- RowManager : composition
ChartQueries *-- MarkerManager : composition

' ============================================
' DOMAIN LAYER - CHART GENERATOR
' ============================================
ChartGenerator --> ChartSection : operates on
ChartGenerator --> NodeManager : creates nodes\n(via ChartSection)
ChartGenerator --> LinkManager : creates links\n(via ChartSection)
ChartGenerator --> PositionCalculator : uses\n(via ChartSection)
ChartGenerator --> Node : creates
ChartGenerator --> Link : creates
ChartGenerator ..> GenerationContext : uses

' ============================================
' DOMAIN LAYER - PROCESSOR
' ============================================
PatternProcessor --> PatternParser : uses
PatternProcessor --> PatternValidator : uses
PatternProcessor ..> PatternContext : uses
PatternProcessor --> ExpandedPattern : returns

' ============================================
' DOMAIN LAYER - PARSER & MARKER
' ============================================
PatternParser ..> IMarkerProvider : uses

' ============================================
' DOMAIN LAYER - POSITION CALCULATOR
' ============================================
PositionCalculator --> LinkManager : uses
PositionCalculator ..> NodeManager : uses

' ============================================
' DOMAIN LAYER - VALIDATORS
' ============================================
ValidationHandler <|-- StitchCountValidationHandler
ValidationHandler <|-- PatternValidationHandler
ValidationHandler <|-- OrderValidationHandler
ValidationHandler <|-- ChartDataValidationHandler
ValidationHandler --> ValidationHandler : next
ValidationHandler --> ValidationRequest : uses
ValidationHandler --> ValidationResult : returns

ValidationChainBuilder --> ValidationHandler : builds
ValidationChainBuilder --> StitchCountValidationHandler : creates
ValidationChainBuilder --> PatternValidationHandler : creates
ValidationChainBuilder --> OrderValidationHandler : creates
ValidationChainBuilder --> ChartDataValidationHandler : creates

ChartService --> ValidationHandler : uses
ChartSection --> ValidationHandler : uses
StitchCountValidationHandler --> StitchCountValidator : delegates
PatternValidationHandler --> PatternValidator : delegates
OrderValidationHandler --> OrderValidator : delegates
ChartDataValidationHandler --> ChartDataValidator : delegates

' ============================================
' DOMAIN LAYER - OPERATIONS
' ============================================
OperationRegistry --> IChartOperation : manages
IChartOperation <|.. CastOnOperation
IChartOperation <|.. AddRowOperation
IChartOperation <|.. CastOnAdditionalOperation
IChartOperation <|.. PlaceOnHoldOperation
IChartOperation <|.. PlaceOnNeedleOperation
IChartOperation <|.. JoinOperation

CastOnOperation --> ChartSection : operates on
AddRowOperation --> ChartSection : operates on
CastOnAdditionalOperation --> ChartSection : operates on
PlaceOnHoldOperation --> ChartSection : operates on
PlaceOnNeedleOperation --> ChartSection : operates on
JoinOperation --> ChartSection : operates on

CastOnOperation ..> PatternContext : uses
AddRowOperation ..> PatternContext : uses
CastOnAdditionalOperation ..> PatternContext : uses
PlaceOnHoldOperation ..> PatternContext : uses
PlaceOnNeedleOperation ..> PatternContext : uses
JoinOperation ..> PatternContext : uses

CastOnOperation --> ValidationResult : returns
AddRowOperation --> ValidationResult : returns
CastOnAdditionalOperation --> ValidationResult : returns
PlaceOnHoldOperation --> ValidationResult : returns
PlaceOnNeedleOperation --> ValidationResult : returns
JoinOperation --> ValidationResult : returns

' ============================================
' INTERFACE IMPLEMENTATIONS
' ============================================
ChartRepository ..|> IChartRepository : implements
MarkerManager ..|> IMarkerProvider : implements
ChartVisualizationObserver ..|> IChartObserver : implements
CastOnOperation ..|> IChartOperation : implements
AddRowOperation ..|> IChartOperation : implements
CastOnAdditionalOperation ..|> IChartOperation : implements
PlaceOnHoldOperation ..|> IChartOperation : implements
PlaceOnNeedleOperation ..|> IChartOperation : implements
JoinOperation ..|> IChartOperation : implements

' ============================================
' DATA LAYER RELATIONSHIPS
' ============================================
IChartRepository <|.. ChartRepository
ChartRepository --> ChartData : stores/loads
ChartRepository --> ChartDataValidator : uses
ChartRepository --> ChartDataSerializer : uses
ChartRepository --> ViewModelMapper : uses
ChartDataValidator --> ValidationResult : returns
ChartDataValidator --> ChartData : validates
ChartDataValidator --> Node : validates
ChartDataValidator --> Link : validates
ChartDataSerializer --> ChartSection : serializes
ChartDataSerializer --> ChartData : creates
ChartDataSerializer --> Node : orders
ChartDataSerializer --> Link : orders

note right of "Presentation Layer"
  **Responsibilities:**
  - User interface rendering
  - User interaction handling
  - Visualization display
  - No business logic
end note

note right of "Domain Layer"
  **Responsibilities:**
  - Pattern processing
  - Chart generation logic
  - Coordinate managers
  - Business rules
  - No UI or data persistence
end note

note right of "Data Layer"
  **Responsibilities:**
  - Data models/structures
  - Data persistence (JSON)
  - Data access
  - No business logic
end note

@enduml
