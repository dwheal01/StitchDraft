@startuml
!theme plain
skinparam classAttributeIconSize 0
skinparam componentStyle rectangle
skinparam maxMessageSize 60
skinparam maxClassSize 60
skinparam maxwidth 20000
skinparam maxheight 20000

package "Presentation Layer" {
    class ChartViewModel {
        + name: str
        + nodes: List<NodeViewModel>
        + links: List<LinkViewModel>
    }
    
    class NodeViewModel {
        + id: str
        + type: str
        + x: float
        + y: float
        + row: int
    }
    
    class LinkViewModel {
        + sourceId: str
        + targetId: str
    }

    class VisualizationView {
         - chartsData: List[ChartViewModel]
         - mapper: ViewModelMapper
         - renderer: ChartRenderer
         - currentChartIndex: int
         --
         + loadChartsData(): void
         + loadIndividualCharts(): void
         + initializeInterface(): void
         + switchTab(chartIndex: int): void
         + renderChart(chartData: ChartViewModel, chartIndex: int): void
         - refreshVisualization(): void
      }
    
    class ChartRenderer {
         --
         + renderNodes(svg: Selection, nodes: List[NodeViewModel]): void
         + renderLinks(svg: Selection, links: List[LinkViewModel], nodes: List[NodeViewModel]): void
         + calculateLayout(nodes: List[NodeViewModel]): Layout
         - _getNodeColor(type: str): str
      }

    class ViewModelMapper {
        + toViewModel(chartData: ChartData): ChartViewModel
        + toNodeViewModel(node: Node): NodeViewModel
        + toLinkViewModel(link: Link): LinkViewModel
    }
    
    class UIController {
        - view: VisualizationView
        --
        + handleTabSwitch(index: int): void
        + downloadChart(index: int): void
        + handleUserInteraction(): void
    }

    interface IBodyFormTemplate {
        + applyTransform(nodes: List<NodeViewModel>): List<NodeViewModel>
        + getTemplateData(): Dict
    }
    
    class BodyFormTemplateRenderer {
        - template: IBodyFormTemplate
        --
        + renderWithTemplate(chart: ChartViewModel, template: IBodyFormTemplate): void
    }

    class ChartVisualizationObserver implements IChartObserver {
        - view: VisualizationView
        - mapper: ViewModelMapper
        --
        + onStitchCountChanged(chart: ChartSection, oldCount: int, newCount: int): void
        + onNodeAdded(chart: ChartSection, node: Node): void
        + onLinkAdded(chart: ChartSection, link: Link): void
        + onRowAdded(chart: ChartSection, row: List[str]): void
        + onMarkerPlaced(chart: ChartSection, side: str, position: int): void
        + onChartStateChanged(chart: ChartSection, event: ChartStateEvent): void
        - updateVisualization(chart: ChartSection): void
    }

    class ChartVisualizationService {
        - chartService: ChartService
        --
        + createVisualizationObserver(view: Any): ChartVisualizationObserver
        + attachVisualizationObserver(chart: ChartSection, observer: Optional[ChartVisualizationObserver]): void
        + getChartViewModel(chart: ChartSection): ChartViewModel
    }
}

package "Domain Layer" {
    interface IChartRepository {
      + saveChart(chartData: ChartData): void
      + loadChart(name: str): ChartData
      + loadAllCharts(): List[ChartData]
      + saveCharts(charts: List[ChartData]): void
    }

    class ChartService {
        - chartRepository: IChartRepository
        - patternProcessor: PatternProcessor
        - chartFactory: ChartSectionFactory
        - validationChain: ValidationHandler
        - serializer: ChartDataSerializer
        --
        + createChart(name: str, start_side: str, sts: int, rows: int): ChartSection
        + processPattern(chart: ChartSection, pattern: str): ExpandedPattern
        + exportChart(chart: ChartSection): ChartData
        + joinCharts(chart1: ChartSection, chart2: ChartSection): ChartSection
        + validateChart(chart: ChartSection, request: ValidationRequest): ValidationResult
        + saveChart(chart: ChartSection): void
        + loadChart(name: str): ChartData
        + loadAllCharts(): List[ChartData]
        + saveCharts(charts: List[ChartSection]): void
    }
    
    class PatternProcessor {
        - patternParser: PatternParser
        --
        + expandPattern(pattern: str, context: PatternContext): ExpandedPattern
        + validatePattern(pattern: str, context: PatternContext): bool
        + processMarkers(pattern: str, context: PatternContext): void
        + validateAndExpand(pattern: str, context: PatternContext): ExpandedPattern

    }
    
    class ChartGenerator {
        --
        + generateNodes(charSection: ChartSection, row: List[str], context: GenerationContext): List[Node]
        + generateLinks(charSection: ChartSection, previousRow: List[Node], currentRow: List[Node]): List[Link]
        + calculatePositions(charSection: ChartSection, row: List[str], previousStitches: List[Node]): List[Position]
        + createNodesForRow(chart: ChartSection, row: List[str], side: str, rowNum: int): void
        + addHorizontalLinks(chart: ChartSection, index: int): void
    }

    class ChartSectionFactory {
        --
        + create(config: ChartConfig): ChartSection
        + createWithDefaults(name: str, start_side: str, sts: int, rows: int): ChartSection
        - createStitchCounter(): StitchCounter
        - createValidator(): StitchCountValidator
        - createValidationChain(): ValidationHandler
        - createRowManager(start_side: str): RowManager
        - createNodeManager(): NodeManager
        - createLinkManager(): LinkManager
        - createPositionCalculator(sts: int, rows: int): PositionCalculator
        - createMarkerManager(): MarkerManager
        - createPatternParser(markerManager: MarkerManager): PatternParser
        - createChartGenerator(positionCalculator: PositionCalculator): ChartGenerator
        - createChartQueries(chart: ChartSection): ChartQueries
        - createOperationRegistry(): OperationRegistry
    }
    
   class ChartSection {
      - name: str
      - start_side: str
      - observers: List[IChartObserver]
      - stitchCounter: StitchCounter
      - validator: StitchCountValidator
      - rowManager: RowManager
      - nodeManager: NodeManager
      - linkManager: LinkManager
      - positionCalculator: PositionCalculator
      - markerManager: MarkerManager
      - patternParser: PatternParser
      - chartGenerator: ChartGenerator
      - chartQueries: ChartQueries
      - operationRegistry: OperationRegistry
      --
      ' Observer management
      + attach(observer: IChartObserver): void
      + detach(observer: IChartObserver): void
      + notifyObservers(event: ChartStateEvent): void
      
      ' High-level operations (delegate to commands)
      + add_row(pattern: Union[str, int], isRound: bool): ChartSection
      + add_round(pattern: Union[str, int]): ChartSection
      + cast_on_start(count: int): void
      + cast_on(count: int): ChartSection
      + place_marker(side: str, position: int): void
      + repeat_rows(patterns: List[str], count: int): void
      + repeat_rounds(patterns: List[str], count: int): void
      + join(other: ChartSection): ChartSection
      + place_on_hold(): List[Node]
      + place_on_needle(stitches_on_hold: List[Node], join_side: str): void
      
      ' Node creation
      + add_nodes(row: List[str], side: str, isRound: bool): void
      
      ' Query methods (delegate to ChartQueries)
      + get_current_row_num(): int
      + get_current_num_of_stitches(): int
      + get_stitches_on_hold(): List[Node]
      + get_row_num(side: str): int
      + get_markers(side: str): List[int]
      + find_last_stitch(): Node
      + find_first_stitch(): Node
      
      ' Properties
      + nodes: List[Node]
      + links: List[Link]
      + rows: List[List[str]]
      
      ' Internal notification methods
      - notifyStitchCountChanged(oldCount: int, newCount: int): void
      - notifyNodeAdded(node: Node): void
      - notifyLinkAdded(link: Link): void
      - notifyRowAdded(row: List[str]): void
      - notifyMarkerPlaced(side: str, position: int): void
   }

   class ChartQueries {
      - chart: ChartSection
      --
      + get_current_num_of_stitches(): int
      + get_current_row_num(): int
      + get_row_num(side: str): int
      + get_stitches_on_hold(): List[Node]
      + get_markers(side: str): List[int]
      + find_last_stitch(): Node
      + find_first_stitch(): Node
   }

   class ChartGenerator {
      - positionCalculator: PositionCalculator
      --
      + generateNodes(chart: ChartSection, row: List[str], context: GenerationContext): List[Node]
      + generateLinks(chart: ChartSection, previousRow: List[Node], currentRow: List[Node]): List[Link]
      + calculatePositions(chart: ChartSection, row: List[str], previousStitches: List[Node]): List[Position]
      + createNodesForRow(chart: ChartSection, row: List[str], side: str, rowNum: int): void
      + addHorizontalLinks(chart: ChartSection, index: int): void
   }

   class PlaceOnHoldOperation implements IChartOperation {
      + execute(chart: ChartSection, params: Dict): ChartSection
      + validate(params: Dict, context: PatternContext): ValidationResult
   }

   class PlaceOnNeedleOperation implements IChartOperation {
      + execute(chart: ChartSection, params: Dict): ChartSection
      + validate(params: Dict, context: PatternContext): ValidationResult
   }

   class JoinOperation implements IChartOperation {
      + execute(chart: ChartSection, params: Dict): ChartSection
      + validate(params: Dict, context: PatternContext): ValidationResult
   }

    interface IMarkerProvider {
        + get_markers(side: str): List[int]
        + move_marker(side: str, position: int, shift_amount: int, num_stitches: int): void
        + remove_marker(side: str, position: int): void
    }
    
    class PatternParser {
      - CONSUME_PRODUCE: Dict[str, Tuple[int, int]]
      - markerProvider: IMarkerProvider
      --
      + expand_pattern(pattern: str, available_stitches: int, side: str): ExpandedPattern
      + split_tokens(pattern: str): List[str]
      + parse_token(token: str): Tuple[str, int]
      - _split_by_sm(pattern: str, side: str): Tuple[List[str], List[int], List[int]]
    }
    
    class RowManager {
        - rows: List[List[str]]
        - start_side: str
        - last_row_side: str
        --
        + set_last_row_side(side: str): void
        + add_row(row: List[str], isRound: bool): void
        + add_round(row: List[str]): void
        + is_wrong_side(isRound: bool): bool
        + reverse_row_if_needed(row: List[str], isRound: bool): List[str]
        + duplicate_row(index: int): List[str]
        - _validate_row_index(index: int): void
    }
    
    class NodeManager {
        - nodes: List[Node]
        - node_counter: int
        - last_row_stitches: List[Node]
        - stitches_on_hold: List[Node]
        --
        + create_stitch_node(stitch: str, fx: float, fy: float, row: int): Node
        + create_strand_node(row: int): Node
        + set_stitches_on_hold(): int
        + places_stitches_on_needle(stitches: List[Node]): void
        + set_last_row_unconsumed_stitches(unconsumed_stitches: List[Node]): void
        + get_stitches_on_hold(): List[Node]
        + set_last_row_produced(produced: int): void
    }
    
    class LinkManager {
        - links: List[Link]
        --
        + add_horizontal_link(source_id: str, target_id: str): void
        + add_vertical_link(source_id: str, target_id: str): void
    }
    
    class PositionCalculator {
        - DEFAULT_SPACING: float
        - ROW_HEIGHT: float
        - BASE_Y_OFFSET: float
        --
        + set_guage(sts: int, rows: int): void
        + calculate_anchors(row: List[str], side: str, previous_stitches: List[Node], link_manager: LinkManager, node_counter: int): tuple[List[float], List[Node]]
        + centered_array(n: int, spacing: int): List[float]
        - _calculate_from_previous_row(row: List[str], side: str, previous_stitches: List[Node], link_manager: LinkManager, node_counter: int): tuple[List[float], List[Node]]
        - _add_increase_decrease_links(stitch: str, prev_i: int, current_i: int, previous_stitches: List[Node], link_manager: LinkManager, node_counter: int): void
        - _is_regular_stitch(stitch: str): bool
        - _calculate_increase_decrease_anchor(i: int, prev_i: int, previous_stitches: List[Node], side: str): float
        - _center_anchors(anchors: List[float], row: List[str]): List[float]
    }
    
    class MarkerManager {
        - markers_rs: List[int]
        - markers_ws: List[int]
        --
        + add_marker(side: str, position: int, num_stitches: int): void
        + get_markers(side: str): List[int]
        + move_marker(side: str, position: int, shift_amount: int, num_stitches: int): void
        + remove_marker(side: str, position: int): void
        + get_markers(side: str): List[int]
    }

    abstract class ValidationHandler {
        - nextHandler: ValidationHandler
        --
        + setNext(handler: ValidationHandler): void
        + handle(request: ValidationRequest): ValidationResult
        + {abstract} validate(request: ValidationRequest): ValidationResult
    }
    
    class ValidationRequest {
        + chart: ChartSection
        + pattern: str
        + nodes: List[Node]
        + links: List[Link]
        + operation: str
        + context: PatternContext
        + consumed: int
        + produced: int
    }

    class StitchCountValidationHandler extends ValidationHandler {
      - validator: StitchCountValidator
      --
      + validate(request: ValidationRequest): ValidationResult
    }

   class PatternValidationHandler extends ValidationHandler {
      - validator: PatternValidator
      --
      + validate(request: ValidationRequest): ValidationResult
    }

   class OrderValidationHandler extends ValidationHandler {
      - validator: OrderValidator
      --
      + validate(request: ValidationRequest): ValidationResult
    }
    
    class ValidationResult {
        + isValid: bool
        + errors: List[str]
        + raiseIfInvalid(): void
    }

    class StitchCounter {
      - currentCount: int
      - history: List[StitchCountEvent]
      --
      + getCurrentCount(): int
      + recordOperation(operation: str, consumed: int, produced: int): void
      + validateConsistency(): void
      + getHistory(): List[StitchCountEvent]
      + reset(count: int): void
   }

   class StitchCountValidator {
        --
        + validateStitchCount(chart: ChartSection, consumed: int, produced: int): ValidationResult
        + validateConsistency(chart: ChartSection): ValidationResult
    }

    class PatternValidator {
        --
        + validatePattern(pattern: str, context: PatternContext): ValidationResult
        + validateTokens(tokens: List[str]): ValidationResult
    }

    class OrderValidator {
        --
        + validateOrder(nodes: List[Node], links: List[Link]): ValidationResult
        + validateLinkIntegrity(links: List[Link], nodes: List[Node]): ValidationResult
    }

    interface IChartOperation {
        + execute(chart: ChartSection, params: Dict): ChartSection
        + validate(params: Dict, context: PatternContext): ValidationResult
    }
    
    class CastOnOperation {
        + execute(chart: ChartSection, params: Dict): ChartSection
        + validate(params: Dict, context: PatternContext): ValidationResult
    }
    
    class AddRowOperation {
        + execute(chart: ChartSection, params: Dict): ChartSection
        + validate(params: Dict, context: PatternContext): ValidationResult
    }

    class CastOnAdditionalOperation {
       + execute(chart: ChartSection, params: Dict): ChartSection
       + validate(params: Dict, context: PatternContext): ValidationResult
    } 
    
    class OperationRegistry {
        - operations: Dict[str, IChartOperation]
        --
        + register(name: str, operation: IChartOperation): void
        + getOperation(name: str): IChartOperation
        + has_operation(name: str): bool:

    }
}

package "Data Layer" {
    class ChartData {
        + name: str
        + nodes: List[Node]
        + links: List[Link]
    }

    class ChartDataSerializer {
        --
        + serialize(chart: ChartSection): str
        + serializeDeterministic(chart: ChartSection): str
        + orderNodes(nodes: List[Node]): List[Node]
        + orderLinks(links: List[Link]): List[Link]
    }
    
    class Node {
        + id: str
        + type: str
        + row: int
        + fx: float
        + fy: float
    }
    
    class Link {
        + source: str
        + target: str
    }
    
    class ChartConfig {
        + name: str
        + start_side: str
        + sts: int
        + rows: int
    }

    class ChartDataValidationHandler extends ValidationHandler {
        - validator: ChartDataValidator
        --
        + validate(request: ValidationRequest): ValidationResult
    }
    
    class ValidationChainBuilder {
         - firstHandler: ValidationHandler
         - lastHandler: ValidationHandler
         --
         + addStitchCountValidation(): ValidationChainBuilder
         + addPatternValidation(): ValidationChainBuilder
         + addOrderValidation(): ValidationChainBuilder
         + addChartDataValidation(): ValidationChainBuilder
         + build(): ValidationHandler
    }

    class ChartRepository {
        - dataPath: str
        - validator: ChartDataValidator
        --
        + saveChart(chartData: ChartData): void
        + loadChart(name: str): ChartData
        + loadAllCharts(): List[ChartData]
        + saveCharts(charts: List[ChartData]): void
    }
    
    class PatternContext {
        + available_stitches: int
        + side: str
        + markers: List[Marker]
        + last_row_side: str
        + is_round: bool
    }
    
    class ExpandedPattern {
        + stitches: List[str]
        + consumed: int
        + produced: int
        + markers: List[int]
    }

    interface IChartObserver {
        + onStitchCountChanged(chart: ChartSection, oldCount: int, newCount: int): void
        + onNodeAdded(chart: ChartSection, node: Node): void
        + onLinkAdded(chart: ChartSection, link: Link): void
        + onRowAdded(chart: ChartSection, row: List[str]): void
        + onMarkerPlaced(chart: ChartSection, side: str, position: int): void
        + onChartStateChanged(chart: ChartSection, event: ChartStateEvent): void
    }
    
    class ChartStateEvent {
        + eventType: str
        + chart: ChartSection
        + data: Dict
        + timestamp: DateTime
    }
}

' ============================================
' PRESENTATION LAYER RELATIONSHIPS
' ============================================
VisualizationView --> ViewModelMapper : uses
VisualizationView --> ChartViewModel : uses
ChartRenderer --> ChartViewModel : renders
ChartRenderer --> NodeViewModel : renders
ChartRenderer --> LinkViewModel : renders
ViewModelMapper --> ChartData : converts from
ViewModelMapper --> Node : converts from
ViewModelMapper --> Link : converts from
BodyFormTemplateRenderer --> IBodyFormTemplate : uses
BodyFormTemplateRenderer --> ChartViewModel : uses
ChartViewModel *-- NodeViewModel : contains
ChartViewModel *-- LinkViewModel : contains
UIController --> VisualizationView : controls
ChartVisualizationService --> ChartService : uses

' ============================================
' DOMAIN LAYER - OBSERVER PATTERN
' ============================================
ChartSection --> IChartObserver : notifies
ChartVisualizationObserver ..|> IChartObserver : implements
ChartVisualizationObserver --> VisualizationView : updates
ChartVisualizationObserver --> ViewModelMapper : uses
ChartVisualizationObserver --> ChartSection : observes
ChartVisualizationObserver ..> ChartStateEvent : uses

' ============================================
' DOMAIN LAYER - SERVICE & FACTORY
' ============================================
ChartService --> IChartRepository : uses
ChartService --> PatternProcessor : uses
ChartService --> ChartGenerator : uses
ChartService --> ChartSection : creates/manages
ChartService --> ChartSectionFactory : uses
ChartService --> ChartDataSerializer : uses
ChartService --> ChartConfig : uses
ChartService --> ChartVisualizationObserver : creates
ChartService --> ChartSection : attaches observer

ChartSectionFactory --> ChartSection : creates
ChartSectionFactory --> StitchCounter : creates
ChartSectionFactory --> StitchCountValidator : creates
ChartSectionFactory --> RowManager : creates
ChartSectionFactory --> NodeManager : creates
ChartSectionFactory --> LinkManager : creates
ChartSectionFactory --> PositionCalculator : creates
ChartSectionFactory --> MarkerManager : creates
ChartSectionFactory --> PatternParser : creates
ChartSectionFactory --> ChartGenerator : creates
ChartSectionFactory --> ChartQueries : creates
ChartSectionFactory --> OperationRegistry : creates
ChartSectionFactory --> ChartConfig : uses
ChartSectionFactory ..> IMarkerProvider : uses

' ============================================
' DOMAIN LAYER - CHART SECTION COMPOSITION
' ============================================
ChartSection *-- RowManager : composition
ChartSection *-- NodeManager : composition
ChartSection *-- LinkManager : composition
ChartSection *-- PositionCalculator : composition
ChartSection *-- MarkerManager : composition
ChartSection *-- PatternParser : composition
ChartSection *-- StitchCounter : composition
ChartSection *-- StitchCountValidator : composition
ChartSection --> ChartGenerator : uses\n(for node creation)
ChartSection --> ChartQueries : uses\n(for queries)
ChartSection --> OperationRegistry : uses\n(for operations)

' ============================================
' DOMAIN LAYER - CHART QUERIES
' ============================================
ChartQueries --> ChartSection : queries
ChartQueries --> NodeManager : queries\n(via ChartSection)
ChartQueries --> MarkerManager : queries\n(via ChartSection)
ChartQueries --> RowManager : queries\n(via ChartSection)

' ============================================
' DOMAIN LAYER - CHART GENERATOR (EXPANDED)
' ============================================
ChartGenerator --> ChartSection : operates on\n(delegation)
ChartGenerator --> NodeManager : creates nodes\n(via ChartSection)
ChartGenerator --> LinkManager : creates links\n(via ChartSection)
ChartGenerator --> PositionCalculator : uses\n(via ChartSection)
ChartGenerator --> OrderValidator : uses
ChartGenerator --> Node : creates
ChartGenerator --> Link : creates

' ============================================
' DOMAIN LAYER - PROCESSOR
' ============================================
PatternProcessor --> PatternParser : uses
PatternProcessor --> PatternValidator : uses
PatternProcessor ..> PatternContext : uses
PatternProcessor --> ExpandedPattern : returns

' ============================================
' DOMAIN LAYER - PARSER & MARKER
' ============================================
PatternParser ..> IMarkerProvider : uses
MarkerManager ..|> IMarkerProvider : implements

' ============================================
' DOMAIN LAYER - POSITION CALCULATOR
' ============================================
PositionCalculator --> LinkManager : uses
PositionCalculator ..> NodeManager : uses

' ============================================
' DOMAIN LAYER - VALIDATORS
' ============================================
' Chain of Responsibility relationships
ValidationHandler <|-- StitchCountValidationHandler
ValidationHandler <|-- PatternValidationHandler
ValidationHandler <|-- OrderValidationHandler
ValidationHandler <|-- ChartDataValidationHandler
ValidationHandler --> ValidationHandler : next
ValidationHandler --> ValidationRequest : uses
ValidationHandler --> ValidationResult : returns

' Chain builder
ValidationChainBuilder --> ValidationHandler : builds
ValidationChainBuilder --> StitchCountValidationHandler : creates
ValidationChainBuilder --> PatternValidationHandler : creates
ValidationChainBuilder --> OrderValidationHandler : creates
ValidationChainBuilder --> ChartDataValidationHandler : creates

' Usage
ChartService --> ValidationHandler : uses
ChartSection --> ValidationHandler : uses
StitchCountValidationHandler --> StitchCountValidator : delegates
PatternValidationHandler --> PatternValidator : delegates
OrderValidationHandler --> OrderValidator : delegates
ChartDataValidationHandler --> ChartDataValidator : delegates

' ============================================
' DOMAIN LAYER - OPERATIONS (EXPANDED)
' ============================================
OperationRegistry --> IChartOperation : manages
CastOnOperation ..|> IChartOperation : implements
AddRowOperation ..|> IChartOperation : implements
ShortRowOperation ..|> IChartOperation : implements
PlaceOnHoldOperation ..|> IChartOperation : implements
PlaceOnNeedleOperation ..|> IChartOperation : implements
JoinOperation ..|> IChartOperation : implements

CastOnOperation --> ChartSection : operates on
AddRowOperation --> ChartSection : operates on
ShortRowOperation --> ChartSection : operates on
PlaceOnHoldOperation --> ChartSection : operates on
PlaceOnNeedleOperation --> ChartSection : operates on
JoinOperation --> ChartSection : operates on

CastOnOperation ..> PatternContext : uses
AddRowOperation ..> PatternContext : uses
ShortRowOperation ..> PatternContext : uses
PlaceOnHoldOperation ..> PatternContext : uses
PlaceOnNeedleOperation ..> PatternContext : uses
JoinOperation ..> PatternContext : uses

CastOnOperation --> ValidationResult : returns
AddRowOperation --> ValidationResult : returns
ShortRowOperation --> ValidationResult : returns
PlaceOnHoldOperation --> ValidationResult : returns
PlaceOnNeedleOperation --> ValidationResult : returns
JoinOperation --> ValidationResult : returns

' ============================================
' DATA LAYER RELATIONSHIPS
' ============================================
ChartRepository --> ChartData : stores/loads
ChartRepository ..|> IChartRepository : implements
ChartRepository --> ChartDataValidator : uses
ChartRepository --> ChartDataSerializer : uses
ChartDataValidator --> ValidationResult : returns
ChartDataValidator --> ChartData : validates
ChartDataValidator --> Node : validates
ChartDataValidator --> Link : validates
ChartDataSerializer --> ChartSection : serializes
ChartDataSerializer --> ChartData : creates
ChartDataSerializer --> Node : orders
ChartDataSerializer --> Link : orders

note right of "Presentation Layer"
  **Responsibilities:**
  - User interface rendering
  - User interaction handling
  - Visualization display
  - No business logic
end note

note right of "Domain Layer"
  **Responsibilities:**
  - Pattern processing
  - Chart generation logic
  - Coordinate managers
  - Business rules
  - No UI or data persistence
end note

note right of "Data Layer"
  **Responsibilities:**
  - Data models/structures
  - Data persistence (JSON)
  - Data access
  - No business logic
end note

@enduml

